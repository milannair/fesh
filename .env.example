# LLM API Configuration (OpenAI-compatible format)
# Default: OpenRouter — supports 200+ models from OpenAI, Anthropic, Google, etc.
# Get your API key at: https://openrouter.ai/keys
LLM_API_KEY=your_openrouter_api_key_here
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL_NAME=openai/gpt-4o-mini

# Optional: OpenRouter dashboard metadata
# OPENROUTER_HTTP_REFERER=https://your-app-url.com
# OPENROUTER_X_TITLE=MiroFish

# ===== Zep Memory Graph Configuration =====
# Free monthly quota is sufficient for basic usage: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Boost LLM Configuration (Optional) =====
# Used for simulation agents — can be a different or cheaper model
# If not using boost config, do not include these variables in your .env file
# LLM_BOOST_API_KEY=your_api_key_here
# LLM_BOOST_BASE_URL=https://openrouter.ai/api/v1
# LLM_BOOST_MODEL_NAME=openai/gpt-4o-mini
